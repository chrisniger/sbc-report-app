# Production example for report.summitdata.one.
# Copy these values into the Hostinger Node app environment panel.
# Do not commit real secrets.

NODE_ENV=production

NEXTAUTH_URL=https://report.summitdata.one
AUTH_URL=https://report.summitdata.one

# Generate one strong value and use the same value for both keys.
NEXTAUTH_SECRET=replace-with-secure-random-secret
AUTH_SECRET=replace-with-secure-random-secret

# Use the Hostinger remote MySQL connection string here.
# Keep special characters in the password URL-encoded.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailbox@example.com
SMTP_PASS=mailbox-password
SMTP_FROM=SBC Reports <mailbox@example.com>
ADMIN_EMAIL=admin@example.com
